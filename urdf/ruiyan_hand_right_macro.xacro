<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Define the macro for the Ruiyan RH2 right hand -->
  <xacro:macro name="ruiyan_hand_right" params="prefix parent *origin">

    <!-- Joint to attach the hand to parent link -->
    <joint name="${prefix}hand_connection_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${prefix}hand_base_link"/>
    </joint>

    <!-- Base link -->
    <link name="${prefix}hand_base_link">
      <inertial>
        <origin xyz="-0.00354104285456125 0.00204598885782099 0.0605396757269698" rpy="0 0 0"/>
        <mass value="0.211569079117232"/>
        <inertia ixx="0.000227960492976313" ixy="2.84392055686079E-07" ixz="5.26461841221454E-06"
                 iyy="0.00014411212671873" iyz="-2.9868718911556E-06" izz="0.000100006031139727"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ruiyan_rh2_hand_description/urdf/meshes/ruihand6y/base_link.STL"/>
        </geometry>
        <material name="">
          <color rgba="0.898039215686275 0.917647058823529 0.929411764705882 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ruiyan_rh2_hand_description/urdf/meshes/ruihand6y/base_link.STL"/>
        </geometry>
      </collision>
    </link>


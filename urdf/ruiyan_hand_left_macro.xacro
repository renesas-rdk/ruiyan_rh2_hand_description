    <joint name="${prefix}fz53" type="revolute">
      <origin xyz="-0.043691 0.011217 0" rpy="-1.5708 1.5695 1.5873"/>
      <parent link="${prefix}fz52_Link"/>
      <child link="${prefix}fz53_Link"/>
      <axis xyz="0 0 -1"/>
      <limit lower="0" upper="0" effort="1" velocity="0.5"/>
    </joint>

    <!-- Three-finger grasp TCP -->
    <link name="${prefix}tcp">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-06"/>
        <inertia ixx="1e-09" ixy="0" ixz="0" iyy="1e-09" iyz="0" izz="1e-09"/>
      </inertial>
    </link>

    <joint name="${prefix}tcp_joint" type="fixed">
      <!-- Measured tcp position relative to base frame -->
      <origin xyz="0.075 -0.020 0.130" rpy="0 0.785398 0"/>
      <parent link="${prefix}hand_base_link"/>
      <child link="${prefix}tcp"/>
    </joint>

  </xacro:macro>

</robot>

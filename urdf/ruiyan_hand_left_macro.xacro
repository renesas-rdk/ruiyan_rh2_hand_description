      </collision>
    </link>

    <joint name="${prefix}fz52" type="revolute">
      <origin xyz="-0.0369 -0.001 0" rpy="0 0 0"/>
      <parent link="${prefix}fz51_Link"/>
      <child link="${prefix}fz52_Link"/>
      <axis xyz="0 0 -1"/>
      <limit lower="0" upper="1.658" effort="1" velocity="0.5"/>
      <mimic joint="${prefix}pinky_proximal_joint" multiplier="1.06399" offset="-0.04545"/>
    </joint>

    <!-- Pinky finger distal -->
    <link name="${prefix}fz53_Link">
      <inertial>
        <origin xyz="-5.01630269825887E-06 0.00358024546548252 -0.0177330754396588" rpy="0 0 0"/>
        <mass value="0.00260328329004836"/>
        <inertia ixx="3.22616272404965E-07" ixy="1.35246112705223E-11" ixz="-1.19647172462991E-10"
                 iyy="3.11389657789929E-07" iyz="9.01411448719963E-08" izz="7.26723107121053E-08"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>

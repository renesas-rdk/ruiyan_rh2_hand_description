<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Define the macro for the Ruiyan RH2 left hand -->
  <xacro:macro name="ruiyan_hand_left" params="prefix parent *origin">

    <!-- Joint to attach the hand to parent link -->
    <joint name="${prefix}hand_connection_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${prefix}hand_base_link"/>
    </joint>

    <!-- Base link -->
    <link name="${prefix}hand_base_link">
      <inertial>
        <origin xyz="-0.00261509912067082 -0.00202384901005411 0.0609899196930254" rpy="0 0 0"/>
        <mass value="0.144625530976132"/>
        <inertia ixx="0.000133309599124317" ixy="-1.82145713429529E-07" ixz="3.32894452619656E-06"
                 iyy="8.49751509488818E-05" iyz="1.7292812695271E-06" izz="6.01735771930698E-05"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ruiyan_rh2_hand_description/meshes/ruihand6z/base_link.STL"/>
        </geometry>
        <material name="">
          <color rgba="0.898039215686275 0.917647058823529 0.929411764705882 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ruiyan_rh2_hand_description/meshes/ruihand6z/base_link.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Thumb proximal yaw -->

    <joint name="${prefix}pinky_proximal_joint" type="revolute">
      <origin xyz="-0.0035 0.029624 0.10795" rpy="0 1.4923 -1.5708"/>
      <parent link="${prefix}hand_base_link"/>
      <child link="${prefix}fz51_Link"/>
      <axis xyz="0 0 -1"/>
      <limit lower="0" upper="1.545" effort="1" velocity="0.5"/>
    </joint>

    <!-- Pinky finger intermediate -->
    <link name="${prefix}fz52_Link">
      <inertial>
        <origin xyz="-0.0162670718963009 -0.000328217017429799 2.67080852364709E-07" rpy="0 0 0"/>

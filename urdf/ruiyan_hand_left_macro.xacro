        <inertia ixx="1.44430667118152E-07" ixy="1.06005742555026E-07" ixz="-5.31901274841338E-11"
                 iyy="7.23506245846155E-07" iyz="2.3839216263499E-11" izz="7.279802802298E-07"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ruiyan_rh2_hand_description/meshes/ruihand6z/fz52_Link.STL"/>
        </geometry>
        <material name="">
          <color rgba="0.658823529411765 0.619607843137255 0.56078431372549 1"/>
        </material>
      </visual>
      <collision>
